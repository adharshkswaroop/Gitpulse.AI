rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles & Data: Strictly owner-only access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to all subcollections (chat_history, saved_stacks, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
